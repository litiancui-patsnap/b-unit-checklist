# 阿里云百炼 API 密钥（必填）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 可选配置
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_TTS_MODEL=qwen3-tts-flash
DASHSCOPE_TTS_VOICE=Cherry
DASHSCOPE_TTS_LANGUAGE=English

# 有道词典（可选，不配置则使用 AI 生成）
# YOUDAO_APP_KEY=your_youdao_app_key
# YOUDAO_APP_SECRET=your_youdao_app_secret

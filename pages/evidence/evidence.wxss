page {
  background: #eef2f7;
}

.evidence-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 24rpx 56rpx;
  color: #172033;
}

.task-card,
.proof-card,
.value-card {
  padding: 30rpx;
  border-radius: 26rpx;
  background: #fff;
  box-shadow: 0 14rpx 36rpx rgba(40, 54, 82, 0.06);
}

.eyebrow {
  color: #71809b;
  font-size: 20rpx;
  font-weight: 700;
}

.task-title {
  margin-top: 14rpx;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.35;
}

.task-meta {
  margin-top: 12rpx;
  color: #65738d;
  font-size: 21rpx;
  line-height: 1.5;
}

.evidence-badge {
  display: inline-flex;
  margin-top: 22rpx;
  padding: 8rpx 15rpx;
  border-radius: 999rpx;
  background: #fff3dc;
  color: #8a6330;
  font-size: 20rpx;
  font-weight: 750;
}

.proof-card,
.value-card {
  margin-top: 20rpx;
}

.section-title,
.value-title {
  font-size: 27rpx;
  font-weight: 800;
}

.proof-prompt {
  margin-top: 12rpx;
  color: #5f6e88;
  font-size: 22rpx;
  line-height: 1.65;
}

.record-panel {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #f7f9fc;
}

.record-state {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #516079;
  font-size: 22rpx;
}

.record-dot {
  width: 15rpx;
  height: 15rpx;
  border-radius: 50%;
  background: #a9b2c1;
}

.recording {
  color: #c84f58;
}

.recording .record-dot {
  background: #e75a62;
  box-shadow: 0 0 0 8rpx rgba(231, 90, 98, 0.12);
}

.record-actions {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.primary-action,
.secondary-action,
.danger-action {
  min-width: 180rpx;
  height: 70rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 17rpx;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 70rpx;
}

.primary-action {
  background: #17233d;
  color: #fff;
}

.secondary-action {
  border: 1rpx solid #dce3ee;
  background: #fff;
  color: #34425a;
}

.danger-action {
  background: #e75a62;
  color: #fff;
}

.primary-action::after,
.secondary-action::after,
.danger-action::after,
.submit-button::after {
  border: 0;
}

.text-action {
  padding: 16rpx;
  color: #b3565d;
  font-size: 20rpx;
}

.permission-tip,
.input-tip {
  margin-top: 14rpx;
  color: #8994a7;
  font-size: 19rpx;
  line-height: 1.5;
}

.evidence-input {
  width: 100%;
  min-height: 220rpx;
  box-sizing: border-box;
  margin-top: 24rpx;
  padding: 22rpx;
  border: 1rpx solid #dfe5ef;
  border-radius: 20rpx;
  background: #f8fafc;
  color: #263149;
  font-size: 23rpx;
  line-height: 1.65;
}

.value-card {
  background: #f7f3ff;
}

.value-title {
  color: #6545a3;
}

.value-item {
  margin-top: 12rpx;
  color: #695b7d;
  font-size: 20rpx;
  line-height: 1.55;
}

.submit-button {
  display: flex;
  width: 100%;
  height: 88rpx;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  padding: 0;
  border-radius: 22rpx;
  background: #2b9c71;
  color: #fff;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1;
}

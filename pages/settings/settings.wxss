page {
  background: #eef2f8;
  color: #17233d;
}

.strategy-page {
  padding: 28rpx;
  padding-bottom: 72rpx;
  background:
    radial-gradient(circle at 0 0, rgba(52, 120, 229, 0.1), transparent 26%),
    #eef2f8;
}

.strategy-hero {
  padding: 36rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #17233d 0%, #29446f 100%);
  box-shadow: 0 18rpx 48rpx rgba(23, 35, 61, 0.18);
  color: #fff;
}

.hero-eyebrow {
  color: #a9c8ff;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 46rpx;
  font-weight: 800;
}

.hero-description {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  line-height: 1.6;
}

.hero-metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 30rpx;
}

.hero-metric {
  padding: 18rpx 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.08);
}

.metric-label,
.metric-value {
  display: block;
}

.metric-label {
  color: rgba(255, 255, 255, 0.58);
  font-size: 19rpx;
}

.metric-value {
  margin-top: 7rpx;
  font-size: 25rpx;
  font-weight: 750;
}

.strategy-card,
.action-card {
  margin-top: 24rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(222, 228, 239, 0.92);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 12rpx 36rpx rgba(30, 47, 78, 0.06);
}

.card-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.card-heading-action {
  align-items: center;
}

.card-title {
  color: #172033;
  font-size: 29rpx;
  font-weight: 800;
}

.card-description {
  margin-top: 9rpx;
  color: #71809b;
  font-size: 21rpx;
  line-height: 1.55;
}

.goal-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.goal-option {
  min-height: 124rpx;
  padding: 20rpx;
  border: 2rpx solid #e4e9f1;
  border-radius: 22rpx;
  background: #f8f9fc;
}

.persona-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 24rpx;
}

.persona-option {
  padding: 22rpx;
  border: 1rpx solid #dfe5ef;
  border-radius: 21rpx;
  background: #f8fafc;
}

.persona-option-active {
  border-color: #3478e5;
  background: #edf4ff;
  box-shadow: inset 0 0 0 1rpx rgba(52, 120, 229, 0.14);
}

.persona-option-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.persona-option-name {
  color: #172033;
  font-size: 24rpx;
  font-weight: 800;
}

.persona-option-check {
  padding: 5rpx 11rpx;
  border-radius: 999rpx;
  background: #3478e5;
  color: #fff;
  font-size: 17rpx;
  font-weight: 700;
}

.persona-option-description,
.persona-option-promise {
  display: block;
  margin-top: 9rpx;
  font-size: 20rpx;
  line-height: 1.5;
}

.persona-option-description {
  color: #66758f;
}

.persona-option-promise {
  color: #3478e5;
  font-weight: 700;
}

.goal-option-active {
  border-color: #3478e5;
  background: #edf4ff;
  box-shadow: 0 8rpx 20rpx rgba(52, 120, 229, 0.1);
}

.goal-option-top,
.preview-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.goal-name {
  font-size: 25rpx;
  font-weight: 750;
}

.goal-check {
  color: #3478e5;
  font-size: 24rpx;
  font-weight: 800;
}

.goal-description {
  display: block;
  margin-top: 10rpx;
  color: #71809b;
  font-size: 20rpx;
  line-height: 1.5;
}

.intensity-list,
.preview-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 24rpx;
}

.intensity-option {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 19rpx;
  border: 2rpx solid #e4e9f1;
  border-radius: 22rpx;
  background: #fff;
}

.intensity-option-active {
  border-color: #3478e5;
  background: #f4f8ff;
}

.intensity-badge,
.preview-level {
  display: flex;
  width: 54rpx;
  height: 54rpx;
  align-items: center;
  justify-content: center;
  flex: 0 0 54rpx;
  border-radius: 17rpx;
  background: #edf1f7;
  color: #53617a;
  font-size: 23rpx;
  font-weight: 800;
}

.intensity-option-active .intensity-badge,
.preview-item-active .preview-level {
  background: #3478e5;
  color: #fff;
}

.intensity-copy,
.preview-copy,
.setting-copy {
  min-width: 0;
  flex: 1;
}

.intensity-name,
.preview-name,
.setting-label {
  color: #202a3c;
  font-size: 24rpx;
  font-weight: 750;
}

.intensity-description,
.preview-description,
.setting-description {
  display: block;
  margin-top: 6rpx;
  color: #75829a;
  font-size: 20rpx;
  line-height: 1.5;
}

.intensity-time {
  color: #3478e5;
  font-size: 20rpx;
  font-weight: 700;
}

.text-action,
.toggle-text {
  flex: 0 0 auto;
  color: #3478e5;
  font-size: 21rpx;
  font-weight: 700;
}

.preview-item {
  display: flex;
  align-items: center;
  gap: 17rpx;
  padding: 18rpx;
  border: 1rpx solid #e4e9f1;
  border-radius: 21rpx;
  background: #fafbfc;
}

.preview-item-active {
  border-color: #bdd2f6;
  background: #f1f6ff;
}

.preview-current {
  padding: 4rpx 9rpx;
  border-radius: 999rpx;
  background: #dceaff;
  color: #3478e5;
  font-size: 17rpx;
  font-weight: 700;
}

.preview-stats {
  display: flex;
  align-items: flex-end;
  flex: 0 0 auto;
  flex-direction: column;
  gap: 5rpx;
  color: #56647c;
  font-size: 19rpx;
  font-weight: 650;
}

.strategy-tip {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #fff7ea;
  color: #8a6330;
  font-size: 20rpx;
  line-height: 1.55;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf0f5;
}

.setting-row:last-child {
  border-bottom: 0;
}

.time-value {
  min-width: 118rpx;
  padding: 13rpx 18rpx;
  border: 1rpx solid #dce3ee;
  border-radius: 16rpx;
  background: #f8fafc;
  color: #3478e5;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}

.service-status {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 18rpx;
  padding: 15rpx 18rpx;
  border-radius: 17rpx;
  background: #f7f9fc;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.status-dot.enabled {
  background: #2b9c71;
}

.status-dot.pending,
.status-dot.checking {
  background: #3478e5;
}

.status-dot.offline {
  background: #e6a84b;
}

.status-text {
  flex: 1;
  min-width: 0;
  font-size: 20rpx;
}

.status-text.enabled {
  color: #237d5b;
}

.status-text.offline {
  color: #8b652e;
}

.status-text.pending,
.status-text.checking {
  color: #3478e5;
}

.service-check-action {
  flex: 0 0 auto;
  padding: 8rpx 13rpx;
  border-radius: 999rpx;
  background: #eaf2ff;
  color: #3478e5;
  font-size: 18rpx;
  font-weight: 700;
}

.developer-settings {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx dashed #d8deea;
}

.developer-title {
  color: #56647c;
  font-size: 22rpx;
  font-weight: 750;
}

.service-field {
  margin-top: 18rpx;
}

.service-label {
  display: block;
  margin-bottom: 8rpx;
  color: #71809b;
  font-size: 20rpx;
}

.service-input {
  width: 100%;
  min-height: 72rpx;
  box-sizing: border-box;
  padding: 16rpx 18rpx;
  border: 1rpx solid #dfe5ef;
  border-radius: 16rpx;
  background: #f8fafc;
  color: #253149;
  font-size: 21rpx;
}

.service-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.method-card {
  overflow: hidden;
}

.method-list {
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #edf0f5;
}

.method-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.method-index {
  color: #3478e5;
  font-size: 21rpx;
  font-weight: 800;
}

.method-title,
.method-description {
  display: block;
}

.method-title {
  color: #263149;
  font-size: 22rpx;
  font-weight: 750;
}

.method-description {
  margin-top: 6rpx;
  color: #71809b;
  font-size: 20rpx;
  line-height: 1.55;
}

.fallback-title {
  margin-top: 26rpx;
  color: #263149;
  font-size: 22rpx;
  font-weight: 750;
}

.fallback-item {
  margin-top: 10rpx;
  padding: 14rpx 17rpx;
  border-radius: 15rpx;
  background: #f6f8fb;
  color: #56647c;
  font-size: 20rpx;
}

.save-button,
.plan-button {
  display: flex;
  width: 100%;
  height: 84rpx;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 750;
  line-height: 1;
}

.save-button {
  background: #17233d;
  color: #fff;
}

.plan-button {
  margin-top: 14rpx;
  border: 1rpx solid #dce3ee;
  background: #fff;
  color: #34425a;
}

.save-button::after,
.plan-button::after {
  border: 0;
}

.reset-action {
  margin-top: 22rpx;
  color: #a26367;
  font-size: 20rpx;
  text-align: center;
}

.version-entry {
  padding: 26rpx 0 0;
  color: #a9b1c0;
  font-size: 18rpx;
  text-align: center;
}

@media (max-width: 360px) {
  .goal-grid,
  .service-grid {
    grid-template-columns: 1fr;
  }

  .hero-metrics {
    grid-template-columns: 1fr 1fr;
  }
}

<view class="strategy-page">
  <view class="strategy-hero">
    <view class="hero-eyebrow">英语学习策略</view>
    <view class="hero-title">{{ selectedGoalLabel }}</view>
    <view class="hero-description">{{ selectedGoalDescription }}</view>
    <view class="hero-metrics">
      <view class="hero-metric">
        <text class="metric-label">默认强度</text>
        <text class="metric-value">{{ selectedIntensityLabel }}</text>
      </view>
      <view class="hero-metric">
        <text class="metric-label">预计用时</text>
        <text class="metric-value">{{ strategyMinutes }} 分钟</text>
      </view>
      <view class="hero-metric">
        <text class="metric-label">英语动作</text>
        <text class="metric-value">{{ strategyTaskCount }} 项</text>
      </view>
    </view>
  </view>

  <view class="strategy-card">
    <view class="card-heading">
      <view>
        <view class="card-title">1. 先决定英语要保持什么能力</view>
        <view class="card-description">目标会影响执行页的单词、听力、口语、阅读和写作任务。</view>
      </view>
    </view>
    <view class="goal-grid">
      <view
        class="goal-option {{ item.value === learningGoal ? 'goal-option-active' : '' }}"
        wx:for="{{ learningGoalOptions }}"
        wx:key="value"
        data-index="{{ index }}"
        bindtap="selectLearningGoal"
      >
        <view class="goal-option-top">
          <text class="goal-name">{{ item.label }}</text>
          <text class="goal-check" wx:if="{{ item.value === learningGoal }}">✓</text>
        </view>
        <text class="goal-description">{{ item.description }}</text>
      </view>
    </view>
  </view>

  <view class="strategy-card">
    <view class="card-heading">
      <view>
        <view class="card-title">2. 选择默认执行强度</view>
        <view class="card-description">首页语言计划不变；这里决定进入英语执行页后默认做多少。</view>
      </view>
    </view>
    <view class="intensity-list">
      <view
        class="intensity-option {{ item.value === dailyIntensity ? 'intensity-option-active' : '' }}"
        wx:for="{{ dailyIntensityOptions }}"
        wx:key="value"
        data-index="{{ index }}"
        bindtap="selectDailyIntensity"
      >
        <view class="intensity-badge">{{ item.value }}</view>
        <view class="intensity-copy">
          <view class="intensity-name">{{ item.label }}</view>
          <view class="intensity-description">{{ item.description }}</view>
        </view>
        <view class="intensity-time">约 {{ item.minutes }} 分钟</view>
      </view>
    </view>
  </view>

  <view class="strategy-card">
    <view class="card-heading card-heading-action">
      <view>
        <view class="card-title">3. 预览英语执行方案</view>
        <view class="card-description">忙碌时做轻量，日常做标准，周末有余力再强化。</view>
      </view>
      <view class="text-action" bindtap="applyGoalDefaults">按目标重建</view>
    </view>
    <view class="preview-list">
      <view class="preview-item {{ item.active ? 'preview-item-active' : '' }}" wx:for="{{ planPreviews }}" wx:key="key">
        <view class="preview-level">{{ item.key }}</view>
        <view class="preview-copy">
          <view class="preview-title-row">
            <text class="preview-name">{{ item.name }}</text>
            <text class="preview-current" wx:if="{{ item.active }}">当前默认</text>
          </view>
          <text class="preview-description">{{ item.description }}</text>
        </view>
        <view class="preview-stats">
          <text>{{ item.taskCount }} 项</text>
          <text>{{ item.minutes }} 分钟</text>
        </view>
      </view>
    </view>
    <view class="strategy-tip">完成标准不是“全部做完才算学习”：达到模板阈值即可保住当天英语习惯。</view>
  </view>

  <view class="strategy-card">
    <view class="card-title">执行提醒</view>
    <view class="setting-row">
      <view class="setting-copy">
        <text class="setting-label">每日提醒</text>
        <text class="setting-description">用于提醒回到计划页检查当天未完成任务。</text>
      </view>
      <switch checked="{{ reminderEnabled }}" bindchange="onReminderSwitch" color="#3478e5" />
    </view>
    <view class="setting-row" wx:if="{{ reminderEnabled }}">
      <view class="setting-copy">
        <text class="setting-label">提醒时间</text>
        <text class="setting-description">建议放在仍有时间完成轻量任务的时段。</text>
      </view>
      <picker mode="time" value="{{ reminderTime }}" bindchange="onTimeChange">
        <view class="time-value">{{ reminderTime }}</view>
      </picker>
    </view>
  </view>

  <view class="strategy-card">
    <view class="card-title">智能学习服务</view>
    <view class="setting-row">
      <view class="setting-copy">
        <text class="setting-label">生成内容、词典与发音</text>
        <text class="setting-description">服务不可用时会自动回退到本地内容，不阻塞学习。</text>
      </view>
      <switch checked="{{ aiService.enabled }}" bindchange="onAIServiceSwitch" color="#3478e5" />
    </view>
    <view class="service-status">
      <view class="status-dot {{ aiServiceStatusClass }}"></view>
      <text class="status-text {{ aiServiceStatusClass }}">{{ aiServiceStatusText }}</text>
    </view>

    <view class="developer-settings" wx:if="{{ showDeveloperSettings }}">
      <view class="developer-title">开发者设置</view>
      <view class="service-field">
        <text class="service-label">调用方式</text>
        <picker mode="selector" range="{{ ['微信云函数', 'HTTP代理'] }}" value="{{ aiService.mode === 'http' ? 1 : 0 }}" bindchange="onAIServiceModeChange">
          <view class="service-input">{{ aiService.mode === 'http' ? 'HTTP代理' : '微信云函数' }}</view>
        </picker>
      </view>
      <view class="service-field">
        <text class="service-label">云函数名</text>
        <input class="service-input" value="{{ aiService.cloudFunctionName }}" bindinput="onAIServiceInput" data-field="cloudFunctionName" placeholder="aiProxy" />
      </view>
      <view class="service-field">
        <text class="service-label">服务地址</text>
        <input class="service-input" value="{{ aiService.baseUrl }}" bindinput="onAIServiceInput" data-field="baseUrl" placeholder="https://你的域名/api" />
      </view>
      <view class="service-field">
        <text class="service-label">提供方</text>
        <input class="service-input" value="{{ aiService.provider }}" bindinput="onAIServiceInput" data-field="provider" placeholder="qwen" />
      </view>
      <view class="service-grid">
        <input class="service-input" value="{{ aiService.dictionaryPath }}" bindinput="onAIServiceInput" data-field="dictionaryPath" placeholder="/dictionary/lookup" />
        <input class="service-input" value="{{ aiService.ttsPath }}" bindinput="onAIServiceInput" data-field="ttsPath" placeholder="/speech/tts" />
        <input class="service-input" value="{{ aiService.contentPath }}" bindinput="onAIServiceInput" data-field="contentPath" placeholder="/learning/content" />
        <input class="service-input" value="{{ aiService.planPath }}" bindinput="onAIServiceInput" data-field="planPath" placeholder="/learning/plan" />
      </view>
    </view>
  </view>

  <view class="strategy-card method-card">
    <view class="card-heading card-heading-action" bindtap="toggleMethodGuide">
      <view>
        <view class="card-title">更容易坚持的使用方法</view>
        <view class="card-description">不是堆学习时长，而是让输入最终变成能说、能写、能回忆。</view>
      </view>
      <view class="toggle-text">{{ showMethodGuide ? '收起' : '查看' }}</view>
    </view>
    <view class="method-list" wx:if="{{ showMethodGuide }}">
      <view class="method-item">
        <text class="method-index">01</text>
        <view><text class="method-title">先完成可执行任务</text><text class="method-description">从计划页进入英语听、说、读、写模块，完成后自动回写进度。</text></view>
      </view>
      <view class="method-item">
        <text class="method-index">02</text>
        <view><text class="method-title">忙碌日主动降级</text><text class="method-description">不要因为做不了强化计划而放弃，切换轻量方案保住连续性。</text></view>
      </view>
      <view class="method-item">
        <text class="method-index">03</text>
        <view><text class="method-title">每周只优化一个动作</text><text class="method-description">在学习记录页检查最常跳过的任务，下周只调整一处。</text></view>
      </view>
      <view class="fallback-title">英文输出兜底句</view>
      <view class="fallback-item" wx:for="{{ diaryTemplates }}" wx:key="*this">{{ item }}</view>
    </view>
  </view>

  <view class="action-card">
    <button class="save-button" bindtap="saveConfig">保存并应用英语策略</button>
    <button class="plan-button" bindtap="goTodayPlan">返回今日计划</button>
    <view class="reset-action" bindtap="resetConfig">恢复默认英语方案</view>
  </view>

  <view class="version-entry" bindtap="onVersionTap">版本 {{ configVersion }}</view>
</view>

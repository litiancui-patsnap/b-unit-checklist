<view class="container">
  <!-- 学习目标 -->
  <view class="section">
    <view class="section-title">英语学习目标</view>
    <view class="reminder-row">
      <view class="option-info">
        <text class="reminder-label">当前目标</text>
        <text class="option-desc">用于生成首页学习定位和分享文案</text>
      </view>
      <picker mode="selector" range="{{ learningGoalOptions }}" range-key="label" value="{{ learningGoalIndex }}" bindchange="onLearningGoalChange">
        <view class="time-picker">{{ learningGoalOptions[learningGoalIndex].label }}</view>
      </picker>
    </view>
    <view class="reminder-row">
      <view class="option-info">
        <text class="reminder-label">每日默认强度</text>
        <text class="option-desc">新的一天会默认展示这个强度的任务</text>
      </view>
      <picker mode="selector" range="{{ dailyIntensityOptions }}" range-key="displayLabel" value="{{ dailyIntensityIndex }}" bindchange="onDailyIntensityChange">
        <view class="time-picker">{{ dailyIntensityOptions[dailyIntensityIndex].label }}</view>
      </picker>
    </view>
    <button class="btn-default" bindtap="applyGoalDefaults">按当前目标生成默认任务</button>
  </view>

  <!-- 学习前准备配置 -->
  <view class="section">
    <view class="section-title">学习前准备</view>
    <view class="config-items">
      <view class="config-item" wx:for="{{ startChecklist }}" wx:key="id">
        <input class="config-input" value="{{ item.text }}" bindinput="onStartInput" data-id="{{ item.id }}" placeholder="输入准备动作" />
        <button class="btn-delete" bindtap="deleteStart" data-id="{{ item.id }}">删除</button>
      </view>
    </view>
    <button class="btn-default" bindtap="addStart">新增一项</button>
  </view>

  <!-- 轻量任务配置 -->
  <view class="section">
    <view class="section-title">轻量英语任务</view>
    <view class="threshold-input-group">
      <text class="threshold-label">完成阈值：</text>
      <input class="threshold-input" type="number" value="{{ templateA.threshold }}" bindinput="onThresholdInput" data-template="A" />
      <text class="threshold-unit">项</text>
    </view>
    <view class="config-items">
      <view class="config-item" wx:for="{{ templateA.items }}" wx:key="id">
        <input class="config-input" value="{{ item.text }}" bindinput="onTemplateInput" data-template="A" data-id="{{ item.id }}" placeholder="输入英语任务" />
        <button class="btn-delete" bindtap="deleteTemplateItem" data-template="A" data-id="{{ item.id }}">删除</button>
      </view>
    </view>
    <button class="btn-default" bindtap="addTemplateItem" data-template="A">新增一项</button>
  </view>

  <!-- 标准任务配置 -->
  <view class="section">
    <view class="section-title">标准英语任务</view>
    <view class="threshold-input-group">
      <text class="threshold-label">完成阈值：</text>
      <input class="threshold-input" type="number" value="{{ templateB.threshold }}" bindinput="onThresholdInput" data-template="B" />
      <text class="threshold-unit">项</text>
    </view>
    <view class="config-items">
      <view class="config-item" wx:for="{{ templateB.items }}" wx:key="id">
        <input class="config-input" value="{{ item.text }}" bindinput="onTemplateInput" data-template="B" data-id="{{ item.id }}" placeholder="输入英语任务" />
        <button class="btn-delete" bindtap="deleteTemplateItem" data-template="B" data-id="{{ item.id }}">删除</button>
      </view>
    </view>
    <button class="btn-default" bindtap="addTemplateItem" data-template="B">新增一项</button>
  </view>

  <!-- 强化任务配置 -->
  <view class="section">
    <view class="section-title">强化英语任务</view>
    <view class="threshold-input-group">
      <text class="threshold-label">完成阈值：</text>
      <input class="threshold-input" type="number" value="{{ templateC.threshold }}" bindinput="onThresholdInput" data-template="C" />
      <text class="threshold-unit">项</text>
    </view>
    <view class="config-items">
      <view class="config-item" wx:for="{{ templateC.items }}" wx:key="id">
        <input class="config-input" value="{{ item.text }}" bindinput="onTemplateInput" data-template="C" data-id="{{ item.id }}" placeholder="输入英语任务" />
        <button class="btn-delete" bindtap="deleteTemplateItem" data-template="C" data-id="{{ item.id }}">删除</button>
      </view>
    </view>
    <button class="btn-default" bindtap="addTemplateItem" data-template="C">新增一项</button>
  </view>

  <!-- 英文日记模板 -->
  <view class="section">
    <view class="section-title">英文日记模板</view>
    <view class="diary-template-preview" wx:for="{{ diaryTemplates }}" wx:key="*this">{{ item }}</view>
  </view>

  <!-- 提醒设置 -->
  <view class="section">
    <view class="section-title">学习提醒</view>
    <view class="reminder-row">
      <text class="reminder-label">开启提醒</text>
      <switch checked="{{ reminderEnabled }}" bindchange="onReminderSwitch" color="#1AAD19" />
    </view>
    <view class="reminder-row">
      <text class="reminder-label">提醒时间</text>
      <picker mode="time" value="{{ reminderTime }}" bindchange="onTimeChange">
        <view class="time-picker">{{ reminderTime }}</view>
      </picker>
    </view>

    <view class="reminder-notice">
      <view class="notice-title">提醒说明</view>
      <view class="notice-content">
        <text class="notice-text">小程序打开时，会在设定时间后提示学习英语</text>
        <text class="notice-text">小程序未打开时，无法收到系统级提醒</text>
        <text class="notice-highlight">建议同时设置手机闹钟，帮助稳定坚持</text>
      </view>
    </view>
  </view>

  <!-- 英语学习方法 -->
  <view class="section">
    <view class="section-title collapsible" bindtap="toggleMethodGuide">
      英语学习方法建议<text class="toggle-icon">{{ showMethodGuide ? '▼' : '▶' }}</text>
    </view>

    <view class="method-guide" wx:if="{{ showMethodGuide }}">
      <view class="guide-section">
        <view class="guide-section-title">核心原则</view>
        <view class="principle-box">
          <text class="principle-text">每天少量完成，比偶尔猛学更重要</text>
          <text class="principle-text">单词、听力、跟读、输出要同时保留</text>
          <text class="principle-text">忙的时候完成轻量任务，避免中断习惯</text>
          <text class="principle-highlight">先坚持 7 天，再追求强度</text>
        </view>
      </view>

      <view class="guide-section">
        <view class="guide-section-title">每日 15 分钟安排</view>
        <view class="time-allocation">
          <text class="time-item">单词复习：5 分钟</text>
          <text class="time-item">听力输入：5 分钟</text>
          <text class="time-item">跟读输出：3 分钟</text>
          <text class="time-item">英文日记：2 分钟</text>
          <text class="time-total">重点是每天接触英语，而不是一次学完所有内容</text>
        </view>
      </view>

      <view class="guide-section">
        <view class="guide-section-title">英文日记模板</view>
        <view class="sentence-templates">
          <text class="template-title">不会写时可以套用：</text>
          <text class="template-item">Today I learned ...</text>
          <text class="template-item">I listened to ... for 10 minutes.</text>
          <text class="template-item">One new word I remember is ...</text>
          <text class="template-item">Tomorrow I will review ...</text>
        </view>
      </view>

      <view class="guide-section">
        <view class="guide-section-title">每周复盘</view>
        <view class="review-checklist">
          <text class="review-item">□ 本周学习了几天？</text>
          <text class="review-item">□ 哪个任务最容易坚持？</text>
          <text class="review-item">□ 哪个任务经常跳过？</text>
          <text class="review-item">□ 下周只优化一个学习动作</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="section">
    <button class="btn-primary" bindtap="saveConfig">保存设置</button>
    <button class="btn-danger" bindtap="resetConfig">恢复默认英语任务</button>
  </view>
</view>

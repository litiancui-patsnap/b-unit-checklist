.onboarding-page {
  padding-bottom: 32px;
}

.hero-section {
  padding: 28px 4px 12px;
}

.hero-title {
  font-size: 26px;
  font-weight: 700;
  color: #1f2d1f;
  line-height: 1.3;
}

.hero-subtitle {
  margin-top: 8px;
  font-size: 14px;
  color: #666;
  line-height: 1.6;
}

.choice-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.choice-item {
  padding: 14px;
  border: 1.5px solid #e5e5e5;
  border-radius: 8px;
  background-color: #fafafa;
}

.choice-item.active {
  border-color: #1AAD19;
  background-color: #f1f8f4;
}

.choice-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.choice-main {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.choice-desc {
  margin-top: 6px;
  font-size: 13px;
  color: #777;
  line-height: 1.5;
}

.minutes-badge {
  flex-shrink: 0;
  padding: 4px 8px;
  border-radius: 999px;
  font-size: 12px;
  color: #1AAD19;
  background-color: #fff;
}

.start-button {
  margin: 18px 0 0;
}

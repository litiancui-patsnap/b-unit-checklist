page {
  background: #eef2f8;
  color: #17233d;
}

.planner-page {
  padding: 28rpx;
  padding-bottom: 64rpx;
  background:
    radial-gradient(circle at 0 0, rgba(52, 120, 229, 0.1), transparent 28%),
    radial-gradient(circle at 100% 8%, rgba(233, 92, 98, 0.08), transparent 24%),
    #eef2f8;
}

.topbar {
  margin-bottom: 24rpx;
}

.brand-title {
  font-size: 52rpx;
  line-height: 1.2;
  font-weight: 800;
  letter-spacing: -2rpx;
}

.brand-subtitle {
  margin-top: 10rpx;
  color: #6d7890;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.55;
}

.date-nav {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
  padding: 8rpx;
  border: 1rpx solid #e1e6ef;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
}

.date-arrow,
.date-current {
  margin: 0;
  padding: 0;
  background: transparent;
  color: #17233d;
  line-height: 70rpx;
}

.date-arrow::after,
.date-current::after {
  border: 0;
}

.date-arrow {
  width: 72rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.date-current {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
}

.card {
  border: 1rpx solid rgba(222, 228, 239, 0.9);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 14rpx 42rpx rgba(30, 47, 78, 0.07);
}

.hero-card {
  padding: 34rpx;
  overflow: hidden;
}

.hero-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.eyebrow {
  color: #71809b;
  font-size: 23rpx;
  font-weight: 700;
}

.focus-title {
  margin-top: 12rpx;
  color: #182033;
  font-size: 42rpx;
  font-weight: 800;
}

.focus-description {
  margin-top: 14rpx;
  color: #69758d;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.65;
}

.progress-ring {
  flex: 0 0 164rpx;
  width: 164rpx;
  height: 164rpx;
  padding: 18rpx;
  border-radius: 50%;
}

.progress-inner {
  display: flex;
  width: 100%;
  height: 100%;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  border-radius: 50%;
  background: #fff;
}

.progress-value {
  font-size: 39rpx;
  font-weight: 800;
}

.progress-label {
  margin-top: 2rpx;
  color: #71809b;
  font-size: 20rpx;
  font-weight: 600;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 30rpx;
}

.stat-box {
  padding: 22rpx;
  border: 1rpx solid #e8edf4;
  border-radius: 22rpx;
  background: #f7f9fc;
}

.stat-box text,
.stat-box .stat-strong {
  display: block;
}

.stat-box text {
  color: #71809b;
  font-size: 21rpx;
}

.stat-box .stat-strong {
  margin-top: 8rpx;
  color: #151d2d;
  font-size: 30rpx;
}

.task-card {
  margin-top: 24rpx;
  padding: 30rpx;
}

.section-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title-main,
.dashboard-title {
  color: #171f30;
  font-size: 31rpx;
  font-weight: 800;
}

.section-caption {
  margin-top: 8rpx;
  color: #71809b;
  font-size: 22rpx;
  font-weight: 600;
}

.execution-hint {
  color: #3478e5;
  font-size: 20rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.task-row {
  display: flex;
  min-height: 118rpx;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid #dfe5ef;
  border-radius: 24rpx;
  background: #fff;
}

.task-done {
  background: #f5fbf8;
  opacity: 0.78;
}

.task-checkbox {
  transform: scale(0.85);
}

.task-content {
  flex: 1;
  min-width: 0;
}

.task-title {
  color: #161d2a;
  font-size: 27rpx;
  font-weight: 750;
}

.task-done .task-title {
  text-decoration: line-through;
}

.task-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 10rpx;
}

.language-tag {
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.language-jp {
  color: #d84d56;
  background: #fff0f0;
}

.language-en {
  color: #3478e5;
  background: #edf4ff;
}

.language-review {
  color: #217d59;
  background: #eef8f3;
}

.resource-name {
  overflow: hidden;
  color: #71809b;
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-side {
  display: flex;
  align-items: flex-end;
  flex-direction: column;
  gap: 7rpx;
}

.task-minutes {
  color: #44526b;
  font-size: 22rpx;
  font-weight: 700;
}

.task-enter {
  color: #3478e5;
  font-size: 20rpx;
  font-weight: 700;
}

.task-delete {
  color: #c86469;
  font-size: 19rpx;
}

.add-task-form {
  display: grid;
  grid-template-columns: 1fr 150rpx 160rpx 96rpx;
  gap: 10rpx;
  margin-top: 24rpx;
}

.task-input,
.picker-field {
  height: 76rpx;
  padding: 0 18rpx;
  border: 1rpx solid #dfe5ef;
  border-radius: 18rpx;
  background: #fff;
  color: #28344a;
  font-size: 22rpx;
  line-height: 76rpx;
}

.picker-field {
  padding: 0 12rpx;
  text-align: center;
}

.add-button {
  height: 76rpx;
  margin: 0;
  padding: 0;
  border-radius: 18rpx;
  background: #17233d;
  color: #fff;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 76rpx;
}

.add-button::after {
  border: 0;
}

.dashboard-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 24rpx;
}

.dashboard-card {
  min-width: 0;
  padding: 28rpx;
}

.week-card,
.resources-card,
.reminder-card {
  grid-column: 1 / -1;
}

.week-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  margin-top: 22rpx;
}

.week-day {
  display: flex;
  min-width: 0;
  padding: 16rpx 4rpx;
  align-items: center;
  flex-direction: column;
  border-radius: 18rpx;
  background: #f5f7fb;
}

.week-name {
  font-size: 23rpx;
  font-weight: 700;
}

.week-date {
  margin-top: 9rpx;
  color: #71809b;
  font-size: 18rpx;
}

.week-active {
  background: #17233d;
  color: #fff;
}

.week-active .week-date {
  color: #dfe6f4;
}

.week-complete::after {
  width: 8rpx;
  height: 8rpx;
  margin-top: 8rpx;
  border-radius: 50%;
  background: #2b9c71;
  content: '';
}

.ratio-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 25rpx;
}

.ratio-label {
  width: 52rpx;
  font-size: 23rpx;
  font-weight: 700;
}

.ratio-track {
  flex: 1;
  height: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e9edf4;
}

.ratio-fill {
  height: 100%;
  border-radius: 999rpx;
}

.ratio-jp {
  background: #ed767e;
}

.ratio-en {
  background: #5d91e8;
}

.ratio-value {
  width: 65rpx;
  text-align: right;
  font-size: 22rpx;
  font-weight: 700;
}

.resource-card {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #f6f8fb;
}

.resource-title {
  color: #1b2333;
  font-size: 24rpx;
  font-weight: 750;
}

.resource-description {
  margin-top: 10rpx;
  color: #71809b;
  font-size: 21rpx;
  line-height: 1.5;
}

.tip-box {
  margin-top: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #f1d5a7;
  border-radius: 22rpx;
  background: #fff8ec;
  color: #76552e;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.65;
}

.reset-button {
  width: 100%;
  height: 76rpx;
  margin: 20rpx 0 0;
  border: 1rpx solid #dfe5ef;
  border-radius: 18rpx;
  background: #fff;
  color: #71809b;
  font-size: 22rpx;
  line-height: 76rpx;
}

.reset-button::after {
  border: 0;
}

.loading-page {
  padding: 160rpx 40rpx;
  color: #71809b;
  text-align: center;
}

@media (max-width: 360px) {
  .stat-grid,
  .dashboard-grid {
    grid-template-columns: 1fr;
  }

  .week-card,
  .resources-card,
  .reminder-card {
    grid-column: auto;
  }

  .add-task-form {
    grid-template-columns: 1fr 1fr;
  }

  .task-input {
    grid-column: 1 / -1;
  }
}

.date-section {
  text-align: center;
  position: relative;
}

.date-display {
  font-size: 22px;
  font-weight: 600;
  color: #1AAD19;
  letter-spacing: 1px;
}

.goal-display {
  margin-top: 8px;
  font-size: 14px;
  color: #666;
}

.complete-badge {
  margin-top: 12px;
  font-size: 16px;
  color: #1AAD19;
  background: linear-gradient(135deg, #e8f5e9 0%, #f1f8f4 100%);
  padding: 8px 20px;
  border-radius: 20px;
  display: inline-block;
  box-shadow: 0 2px 8px rgba(26, 173, 25, 0.1);
}

.stats-section {
  display: flex;
  justify-content: space-around;
  gap: 8px;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-label {
  display: block;
  font-size: 12px;
  color: #999;
  margin-bottom: 5px;
}

.stat-value {
  display: block;
  font-size: 24px;
  font-weight: bold;
  color: #1AAD19;
}

.reminder-section {
  text-align: center;
}

.reminder-text {
  font-size: 14px;
  color: #ff9800;
}

.section-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.section-header-row .section-title {
  margin-bottom: 0;
}

.source-badge {
  flex-shrink: 0;
  padding: 3px 8px;
  border-radius: 999px;
  background-color: #edf8ed;
  color: #1AAD19;
  font-size: 12px;
}

.content-card {
  padding: 12px;
  border: 1px solid #edf0ed;
  border-radius: 8px;
  background-color: #fcfdfc;
  margin-bottom: 10px;
}

.content-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 8px;
}

.content-label {
  font-size: 13px;
  color: #1AAD19;
  font-weight: 600;
}

.content-text {
  font-size: 13px;
  color: #444;
  line-height: 1.7;
  word-break: break-word;
  margin-bottom: 10px;
}

.content-text.strong {
  font-size: 15px;
  color: #222;
  font-weight: 600;
}

.plan-summary {
  padding: 14px;
  border-radius: 8px;
  background-color: #f7fbf7;
  border: 1px solid #e4f1e4;
}

.plan-summary-main {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.plan-summary-title {
  font-size: 17px;
  font-weight: 600;
  color: #233323;
}

.plan-summary-desc {
  font-size: 13px;
  color: #666;
  line-height: 1.6;
}

.module-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 12px;
}

.module-chip {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 7px 10px;
  border-radius: 999px;
  background-color: #f5f5f5;
}

.module-name {
  font-size: 13px;
  color: #333;
  font-weight: 600;
}

.module-meta {
  font-size: 12px;
  color: #777;
}

.actions-section {
  display: flex;
  flex-direction: column;
}

.diary-template-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 12px;
}

.diary-header-row {
  margin-bottom: 14px;
}

.diary-template {
  min-height: 42px;
  padding: 8px 10px;
  border-radius: 8px;
  background-color: #f8f9fa;
  color: #365136;
  font-size: 13px;
  line-height: 1.5;
  display: flex;
  align-items: center;
  gap: 8px;
  box-sizing: border-box;
}

.diary-template-text {
  flex: 1;
  min-width: 0;
  word-break: break-word;
}

.diary-template:active {
  background-color: #edf6ed;
}

.diary-input {
  width: 100%;
  min-height: 110px;
  border: 1.5px solid #e0e0e0;
  border-radius: 8px;
  padding: 12px;
  font-size: 14px;
  line-height: 1.6;
  background-color: #fafafa;
  box-sizing: border-box;
}

.diary-hint {
  margin-top: 10px;
  font-size: 12px;
  color: #999;
  line-height: 1.6;
}

.share-textarea {
  width: 100%;
  min-height: 150px;
  border: 1.5px solid #e0e0e0;
  border-radius: 8px;
  padding: 12px;
  font-size: 13px;
  line-height: 1.8;
  background-color: #fafafa;
  color: #333;
  box-sizing: border-box;
}

.share-card-preview {
  display: flex;
  gap: 12px;
  padding: 12px;
  border: 1px solid #e4f1e4;
  border-radius: 8px;
  background-color: #f7fbf7;
}

.share-cover {
  flex-shrink: 0;
  width: 72px;
  height: 54px;
  border-radius: 6px;
  background-color: #edf0ed;
}

.share-card-main {
  min-width: 0;
  flex: 1;
}

.share-card-title {
  font-size: 15px;
  font-weight: 600;
  color: #233323;
  line-height: 1.45;
  word-break: break-word;
}

.share-card-desc {
  margin-top: 5px;
  font-size: 12px;
  color: #6f7f6f;
  line-height: 1.5;
}

.share-action-row {
  display: flex;
  gap: 10px;
  margin: 12px auto;
  width: 88%;
  box-sizing: border-box;
}

.share-card-button,
.share-copy-button {
  flex: 1;
  min-width: 0;
  margin: 0;
  padding-left: 8px;
  padding-right: 8px;
  font-size: 14px;
  line-height: 1.4;
  box-sizing: border-box;
  white-space: nowrap;
}

.recent-section {
}

.recent-list {
}

.recent-item {
  display: flex;
  justify-content: space-between;
  padding: 8px 0;
  border-bottom: 1px solid #f0f0f0;
  font-size: 13px;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-date {
  flex: 2;
  color: #666;
}

.recent-template {
  flex: 1;
  text-align: center;
  color: #1AAD19;
}

.recent-complete {
  flex: 1;
  text-align: right;
}

.empty-state {
  text-align: center;
  padding: 40px 20px;
}

.empty-text {
  font-size: 14px;
  color: #999;
}

.compact {
  padding: 18px 10px;
}

.wordbook-summary,
.scene-summary,
.quiz-summary {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 12px;
}

.summary-text {
  font-size: 12px;
  color: #777;
  line-height: 1.5;
}

.word-input-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 8px;
}

.word-input {
  width: 100%;
  min-width: 0;
  height: 40px;
  border: 1.5px solid #e0e0e0;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 14px;
  line-height: 40px;
  background-color: #fafafa;
  box-sizing: border-box;
}

.word-input-full {
  grid-column: 1 / -1;
}

.word-picker {
  color: #1AAD19;
}

.word-action-row {
  display: flex;
  gap: 8px;
  width: 88%;
  margin: 10px auto;
  box-sizing: border-box;
}

.compact-btn {
  flex: 1;
  min-width: 0;
  margin: 0;
  font-size: 13px;
  padding: 9px 8px;
  line-height: 1.4;
  box-sizing: border-box;
  white-space: nowrap;
}

.word-list,
.review-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 12px;
}

.word-card,
.review-card,
.scene-card,
.quiz-card {
  padding: 12px;
  border: 1px solid #edf0ed;
  border-radius: 8px;
  background-color: #fcfdfc;
}

.word-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 6px;
}

.word-title-row {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8px;
}

.word-term {
  min-width: 0;
  flex: 1;
  font-size: 16px;
  color: #222;
  font-weight: 600;
  word-break: break-word;
}

.word-status {
  flex-shrink: 0;
  font-size: 12px;
  color: #1AAD19;
  background-color: #edf8ed;
  border-radius: 999px;
  padding: 3px 8px;
}

.word-translation,
.word-example {
  display: block;
  font-size: 13px;
  color: #666;
  line-height: 1.6;
  word-break: break-word;
}

.word-meta-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6px;
  margin-bottom: 6px;
}

.word-phonetic,
.word-category,
.word-source {
  font-size: 12px;
  color: #777;
  background-color: #f4f6f4;
  border-radius: 999px;
  padding: 3px 8px;
}

.word-category {
  color: #1AAD19;
  background-color: #edf8ed;
}

.word-example {
  color: #888;
  margin-top: 3px;
}

.word-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 10px;
}

.mini-btn {
  margin: 0;
  padding: 6px 10px;
  border-radius: 6px;
  border: 1px solid #dfe5df;
  background-color: #fff;
  color: #555;
  font-size: 12px;
  line-height: 1.4;
}

.mini-btn::after {
  border: none;
}

.mini-btn.primary {
  border-color: #1AAD19;
  color: #1AAD19;
}

.mini-btn.danger {
  border-color: #ffccc7;
  color: #ff4d4f;
}

.sound-btn {
  flex: 0 0 26px;
  width: 26px;
  height: 26px;
  max-width: 26px;
  margin: 0;
  padding: 0;
  border: 1px solid #dfe7df;
  border-radius: 50%;
  background-color: #fbfdfb;
  color: #1AAD19;
  font-size: 12px;
  line-height: 26px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  overflow: hidden;
}

.sound-btn::after {
  border: none;
}

.scene-card {
  margin-bottom: 10px;
}

.scene-card:last-child {
  margin-bottom: 0;
}

.scene-title {
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
}

.scene-line {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 0;
}

.scene-text {
  min-width: 0;
  flex: 1;
  font-size: 13px;
  color: #444;
  line-height: 1.6;
  word-break: break-word;
}

.scene-sound-btn {
  flex-basis: 24px;
  width: 24px;
  height: 24px;
  max-width: 24px;
  border-color: #e1ebe1;
  font-size: 11px;
  line-height: 24px;
}

.diary-sound-btn {
  flex-basis: 24px;
  width: 24px;
  height: 24px;
  max-width: 24px;
  border-color: #e1ebe1;
  font-size: 11px;
  line-height: 24px;
}

.quiz-card {
  margin-bottom: 12px;
}

.quiz-prompt {
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-bottom: 10px;
}

.quiz-options {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 8px;
}

.quiz-option {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  margin: 0;
  min-height: 38px;
  padding: 8px 10px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  background-color: #fff;
  color: #333;
  font-size: 13px;
  line-height: 1.4;
  box-sizing: border-box;
  overflow-wrap: break-word;
  white-space: normal;
}

.quiz-option::after {
  border: none;
}

.quiz-option.selected {
  border-color: #8bbf8b;
  background-color: #f2faf2;
}

.quiz-option.correct {
  border-color: #1AAD19;
  color: #1AAD19;
}

.rescue-hint {
  margin: 0 0 8px;
  font-size: 12px;
  color: #f57c00;
  line-height: 1.6;
  text-align: center;
}

<view class="planner-page" wx:if="{{ !isLoading }}">
  <view class="topbar">
    <view class="brand-block">
      <view class="brand-title">语言学习计划</view>
      <view class="brand-subtitle">先选今天的状态，再完成最值得做的一件事</view>
    </view>
    <view class="date-nav">
      <button class="date-arrow" bindtap="previousDay">‹</button>
      <button class="date-current" bindtap="goToday">{{ dateTitle }}</button>
      <button class="date-arrow" bindtap="nextDay">›</button>
    </view>
  </view>

  <view class="route-hero card">
    <view class="route-hero-top">
      <view class="route-heading">
        <view class="persona-line">
          <text class="persona-name">{{ personaName }}</text>
          <text class="persona-promise">{{ personaPromise }}</text>
        </view>
        <view class="route-kicker">{{ routeLabel }}</view>
        <view class="route-time" wx:if="{{ !routeCompleted }}">当前路线 <text>{{ routeMinutes }}</text> 分钟</view>
        <view class="route-time" wx:else>今天的路线已完成</view>
        <view class="route-description">{{ routeDescription }} · {{ focusTitle }}</view>
      </view>
      <view class="route-progress">
        <text class="route-progress-value">{{ progress }}%</text>
        <text class="route-progress-label">已完成</text>
      </view>
    </view>

    <view class="mode-title">今天是什么状态？</view>
    <view class="mode-selector">
      <view
        class="mode-option {{ item.active ? 'mode-option-active' : '' }} {{ item.disabled ? 'mode-option-disabled' : '' }}"
        wx:for="{{ dayModes }}"
        wx:key="value"
        bindtap="selectDayMode"
        data-mode="{{ item.value }}"
      >
        <text class="mode-symbol">{{ item.symbol }}</text>
        <text class="mode-label">{{ item.label }}</text>
      </view>
    </view>

    <view class="main-quest" wx:if="{{ mainTask }}">
      <view class="quest-topline">
        <view class="quest-label">主线任务</view>
        <view class="quest-time">{{ mainTask.minutes }} 分钟</view>
      </view>
      <view class="quest-title">{{ mainTask.title }}</view>
      <view class="quest-resource">{{ mainTask.resource }}</view>
      <view class="quest-proof">完成后提交：{{ mainTask.evidenceLabel }}</view>
      <view
        class="quest-start"
        hover-class="quest-start-active"
        bindtap="openTask"
        data-type="{{ mainTask.executionType }}"
        data-id="{{ mainTask.id }}"
        data-title="{{ mainTask.title }}"
        data-language="{{ mainTask.language }}"
      >开始主线任务 <text>→</text></view>
    </view>

    <view class="route-complete" wx:else>
      <view class="complete-symbol">✓</view>
      <view class="complete-title">今天的学习成果已经收好</view>
      <view class="complete-description">可以去复盘页查看证据，也可以展开全部任务重新挑战。</view>
    </view>

    <view class="next-route" wx:if="{{ nextTasks.length }}">
      <view class="next-route-title">接下来</view>
      <view
        class="next-task"
        hover-class="next-task-active"
        wx:for="{{ nextTasks }}"
        wx:key="id"
        bindtap="openTask"
        data-type="{{ item.executionType }}"
        data-id="{{ item.id }}"
        data-title="{{ item.title }}"
        data-language="{{ item.language }}"
      >
        <view class="next-index">{{ index + 2 }}</view>
        <view class="next-copy">
          <text class="next-title">{{ item.title }}</text>
          <text class="next-proof">{{ item.evidenceLabel }}</text>
        </view>
        <text class="next-minutes">{{ item.minutes }} 分</text>
      </view>
      <view class="hidden-route" wx:if="{{ hiddenRouteCount }}">还有 {{ hiddenRouteCount }} 项，按完成情况继续解锁</view>
    </view>

    <view class="adjustment-note" wx:if="{{ planAdjustment }}">
      <view class="adjustment-label">系统已根据复盘调整 · {{ planAdjustment.mode }}</view>
      <view class="adjustment-title">{{ planAdjustment.title }}</view>
    </view>

    <view class="route-stats">
      <view><text>{{ completedTaskCount }}/{{ tasks.length }}</text><text>完成任务</text></view>
      <view><text>{{ completedMinutes }}</text><text>成果分钟</text></view>
      <view><text>{{ streak }}</text><text>连续天数</text></view>
    </view>
  </view>

  <view class="all-task-entry card" hover-class="all-task-entry-active" bindtap="toggleAllTasks">
    <view>
      <view class="all-task-title">全部任务与自定义计划</view>
      <view class="all-task-caption">查看 {{ tasks.length }} 项完整任务、证据状态和添加入口</view>
    </view>
    <view class="all-task-toggle">{{ showAllTasks ? '收起' : '展开' }} {{ showAllTasks ? '↑' : '↓' }}</view>
  </view>

  <view class="task-card card" wx:if="{{ showAllTasks }}">
    <view class="section-heading">
      <view>
        <view class="section-title-main">全部任务</view>
        <view class="section-caption">{{ tasks.length }} 项任务 · 已完成 {{ completedTaskCount }} 项</view>
      </view>
      <view class="execution-hint">完成需提交学习证据</view>
    </view>

    <view class="task-list">
      <view class="task-row {{ item.checked ? 'task-done' : '' }}" wx:for="{{ tasks }}" wx:key="id">
        <checkbox class="task-checkbox" checked="{{ item.checked }}" color="#2b9c71" catchtap="toggleTask" data-id="{{ item.id }}" />
        <view class="task-content" bindtap="openTask" data-type="{{ item.executionType }}" data-id="{{ item.id }}" data-title="{{ item.title }}" data-language="{{ item.language }}">
          <view class="task-title">{{ item.title }}</view>
          <view class="task-meta">
            <text class="language-tag {{ item.languageClass }}">{{ item.languageLabel }}</text>
            <text class="resource-name">{{ item.resource }}</text>
          </view>
          <view class="task-proof-row">
            <text class="proof-tag {{ item.hasEvidence ? 'proof-done' : '' }}">{{ item.hasEvidence ? '✓ 已留证据' : item.evidenceLabel }}</text>
            <text class="adaptive-tag" wx:if="{{ item.adaptiveNote }}">智能调整 · {{ item.adaptiveNote }}</text>
          </view>
        </view>
        <view class="task-side">
          <text class="task-minutes">{{ item.minutes }} 分钟</text>
          <text class="task-enter" wx:if="{{ item.canExecute }}" bindtap="openTask" data-type="{{ item.executionType }}" data-id="{{ item.id }}" data-title="{{ item.title }}" data-language="{{ item.language }}">{{ item.hasEvidence ? '查看证据' : '开始并提交' }} ›</text>
          <text class="task-delete" wx:if="{{ item.isCustom }}" catchtap="deleteCustomTask" data-id="{{ item.id }}">删除</text>
        </view>
      </view>
    </view>

    <view class="add-task-form">
      <input class="task-input" value="{{ customTitle }}" bindinput="onCustomTitleInput" maxlength="40" placeholder="添加自己的学习任务" />
      <picker class="task-picker" mode="selector" range="{{ languageOptions }}" range-key="label" value="{{ languageIndex }}" bindchange="onLanguageChange">
        <view class="picker-field">{{ languageOptions[languageIndex].label }}⌄</view>
      </picker>
      <picker class="task-picker" mode="selector" range="{{ minuteOptions }}" value="{{ minuteIndex }}" bindchange="onMinuteChange">
        <view class="picker-field">{{ minuteOptions[minuteIndex] }}分钟⌄</view>
      </picker>
      <view class="add-button" hover-class="add-button-active" bindtap="addCustomTask">添加</view>
    </view>
  </view>

  <view class="dashboard-grid">
    <view class="card dashboard-card week-card">
      <view class="dashboard-title">本周节奏</view>
      <view class="week-grid">
        <view class="week-day {{ item.active ? 'week-active' : '' }} {{ item.complete ? 'week-complete' : '' }}" wx:for="{{ weekDays }}" wx:key="date" bindtap="selectWeekDay" data-date="{{ item.date }}">
          <text class="week-name">{{ item.weekday }}</text>
          <text class="week-date">{{ item.shortDate }}</text>
        </view>
      </view>
    </view>

    <view class="card dashboard-card ratio-card">
      <view class="dashboard-title">今日语言比例</view>
      <view class="ratio-row">
        <text class="ratio-label">日语</text>
        <view class="ratio-track"><view class="ratio-fill ratio-jp" style="width: {{ japaneseRatio }}%;"></view></view>
        <text class="ratio-value">{{ japaneseRatio }}%</text>
      </view>
      <view class="ratio-row">
        <text class="ratio-label">英语</text>
        <view class="ratio-track"><view class="ratio-fill ratio-en" style="width: {{ englishRatio }}%;"></view></view>
        <text class="ratio-value">{{ englishRatio }}%</text>
      </view>
    </view>

    <view class="card dashboard-card resources-card">
      <view class="dashboard-title">对应资料</view>
      <view class="resource-card" wx:for="{{ resources }}" wx:key="id">
        <view class="resource-title">{{ index + 1 }}. {{ item.name }}</view>
        <view class="resource-description">{{ item.description }}</view>
      </view>
    </view>

    <view class="card dashboard-card reminder-card">
      <view class="dashboard-title">学习提醒</view>
      <view class="tip-box">{{ dailyTip }}</view>
      <button class="reset-button" bindtap="resetDay">重置当天打卡</button>
    </view>
  </view>
</view>

<view class="loading-page" wx:else>正在生成今天的学习计划...</view>

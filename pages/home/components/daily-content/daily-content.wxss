.content-section {
  padding: 24rpx;
}

.section-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.source-badge {
  padding: 4rpx 12rpx;
  background: #F0F0F0;
  color: #666;
  font-size: 22rpx;
  border-radius: 12rpx;
}

.content-card {
  background: white;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.content-card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.content-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1AAD19;
}

.sound-btn {
  padding: 4rpx 8rpx;
  font-size: 28rpx;
  cursor: pointer;
}

.content-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 12rpx;
}

.content-text.strong {
  font-weight: 500;
  color: #000;
}

.content-text-secondary {
  font-size: 24rpx;
  line-height: 1.5;
  color: #999;
  margin-bottom: 12rpx;
}

.mini-btn {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  border: 1rpx solid #ddd;
  background: white;
  color: #666;
}

.mini-btn.primary {
  background: #1AAD19;
  color: white;
  border-color: #1AAD19;
}

.empty-state {
  text-align: center;
  padding: 60rpx 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

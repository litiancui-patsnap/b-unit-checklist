<view class="container">
  <!-- 使用说明 -->
  <view class="section instruction-section">
    <view class="instruction-title">学习记录说明</view>
    <view class="instruction-content">
      <text class="instruction-text">点击“一键复制”可复制最近 30 天英语学习记录</text>
      <text class="instruction-text">记录包含本周完成天数、任务完成情况和英文日记</text>
      <text class="instruction-text">开启“仅完成日”可过滤未完成记录</text>
    </view>
  </view>

  <!-- 导出选项 -->
  <view class="section">
    <view class="section-title">筛选选项</view>
    <view class="export-option">
      <view class="option-info">
        <text class="option-label">仅导出完成日</text>
        <text class="option-desc">只显示完成英语学习的日期</text>
      </view>
      <switch checked="{{ onlyCompleted }}" bindchange="onOnlyCompletedChange" color="#1AAD19" />
    </view>
  </view>

  <!-- 导出文本 -->
  <view class="section">
    <view class="section-title">学习记录 / 周报</view>
    <view class="record-stats">
      <text class="stats-text">共 {{ totalDays }} 天学习记录，已完成 {{ completedDays }} 天</text>
    </view>
    <textarea class="export-textarea" value="{{ exportText }}" disabled maxlength="-1" show-confirm-bar="{{ false }}" />
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="btn-primary btn-large" bindtap="copyText">
      <text class="btn-text">一键复制</text>
    </button>
    <button class="btn-secondary" bindtap="refreshExport">
      <text class="btn-text">刷新数据</text>
    </button>
  </view>
</view>
